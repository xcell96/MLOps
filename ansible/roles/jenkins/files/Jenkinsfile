pipeline {
    agent any

    stages {
        stage('Validate Compose') {
            steps {
                sh 'sudo podman compose -f /opt/llm/compose.yaml config'
            }
        }

        stage('Pull Images') {
            steps {
                sh 'sudo podman compose -f /opt/llm/compose.yaml pull'
            }
        }

        stage('Deploy') {
            steps {
                sh 'sudo podman compose -f /opt/llm/compose.yaml up -d'
            }
        }

        stage('Wait for Open WebUI') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    sh '''
                        until curl -fsS http://localhost:3000 > /dev/null; do
                            echo "Waiting for Open WebUI..."
                            sleep 5
                        done
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh 'curl http://localhost:3000'
            }
        }
    }
}
